# Copy to docker/.env and edit before running:
#   docker compose -f docker/docker-compose.yml --env-file docker/.env up -d --build
#
# Defaults are dev-only. Change MINIO_ROOT_PASSWORD and the bearer
# token in docker/preferences.json before exposing this stack.

# minio object-storage credentials
MINIO_ROOT_USER=clankadmin
MINIO_ROOT_PASSWORD=clankadmin

# Host port mappings — tweak if you have local conflicts.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CLANKD_PORT=7878
CLANK_AUTH_STUB_PORT=7879

# clank-auth-stub: dev-only OAuth device-flow server. Auto-approves
# every login attempt and mints an HS256 JWT — never run this where
# untrusted clients can reach it. The secret should match between
# the stub (CLANK_AUTH_STUB_SECRET) and any clankd that verifies
# JWTs (future CLANK_JWT_SECRET when JWT mode lands).
CLANK_AUTH_STUB_SECRET=dev-secret-change-me
CLANK_AUTH_STUB_USER_ID=dev-user
CLANK_AUTH_STUB_EMAIL=dev@clank.local

# Bearer the dev clankd accepts on every inbound request. Laptop sets
# cloud.access_token to the same value (or use `clank login` once the
# auth-server stub lands). Change before exposing this stack.
CLANK_AUTH_TOKEN=clank-dev-token-change-me

# Embedded sync substrate settings (read by clankd in TCP mode).
CLANK_BUCKET=clank
CLANK_SYNC_PRESIGN_TTL=5m

# Publicly-reachable URL of the minio bucket. Baked into presigned
# URLs so a remote sprite (fly.io etc.) can pull from the same
# hostname the laptop uses for upload. Leave empty for laptop-only
# smoke testing (relies on `127.0.0.1 clank-minio` in /etc/hosts).
# For a real sprite, run `make dev` to spawn a cloudflared tunnel and
# auto-write this value; or `make tunnel` and paste manually.
# CLANK_SYNC_S3_PUBLIC_ENDPOINT=https://<words>.trycloudflare.com

# Public base URL of clankd, used when sprites push back checkpoints
# during clank pull --migrate. For real cloud sprites set this to a
# publicly reachable URL of clankd (e.g. another cloudflared tunnel
# pointing at port 7878).
# CLANK_PUBLIC_BASE_URL=https://<words>.trycloudflare.com
