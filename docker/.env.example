# Copy to docker/.env and edit before running:
#   docker compose -f docker/docker-compose.yml --env-file docker/.env up -d --build
#
# Defaults are dev-only. Change MINIO_ROOT_PASSWORD and the bearer
# token in docker/preferences.json before exposing this stack.

# minio object-storage credentials
MINIO_ROOT_USER=clankadmin
MINIO_ROOT_PASSWORD=clankadmin

# Host port mappings — tweak if you have local conflicts.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CLANKD_PORT=7878

# Bearer the dev clankd accepts on every inbound request. Laptop sets
# cloud.access_token to the same value (or use `clank login` once the
# auth-server stub lands). Change before exposing this stack.
CLANK_AUTH_TOKEN=clank-dev-token-change-me

# Embedded sync substrate settings (read by clankd in TCP mode).
CLANK_BUCKET=clank
CLANK_SYNC_PRESIGN_TTL=5m

# Public base URL of clankd, used when sprites push back checkpoints
# (P6). For local-only smoke testing the default is fine. For real
# fly.io sprites you'll need a cloudflared tunnel pointing at port
# 7878; see `make cloud-hub` for the existing tunnel script.
# CLANK_PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com
