# Copy to docker/.env and edit before running:
#   docker compose -f docker/docker-compose.yml --env-file docker/.env up -d --build
#
# Defaults are dev-only. Change MINIO_ROOT_PASSWORD and the bearer
# token in docker/preferences.json before exposing this stack.

# minio object-storage credentials
MINIO_ROOT_USER=clankadmin
MINIO_ROOT_PASSWORD=clankadmin

# Host port mappings — tweak if you have local conflicts.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CLANKD_PORT=7878
CLANK_AUTH_STUB_PORT=7879

# clank-auth-stub: dev-only OAuth 2.0 + PKCE server. Auto-approves
# every authorization request and mints an HS256 JWT — never run this
# where untrusted clients can reach it. The secret must match between
# the stub (CLANK_AUTH_STUB_SECRET) and clankd's CLANK_AUTH_JWT_SECRET
# (the docker-compose wires them to the same value by default).
CLANK_AUTH_STUB_SECRET=dev-secret-change-me
CLANK_AUTH_STUB_USER_ID=dev-user
CLANK_AUTH_STUB_EMAIL=dev@clank.local

# OAuth 2.0 discovery values that clankd returns from GET /auth-config.
# Defaults point at the auth-stub via the host port mapping. Override
# these to plug clankd into a real IdP (Supabase OAuth Server, Auth0,
# Keycloak, …) without touching code.
# CLANK_AUTH_AUTHORIZE_ENDPOINT=http://localhost:7879/authorize
# CLANK_AUTH_TOKEN_ENDPOINT=http://localhost:7879/token
# CLANK_AUTH_CLIENT_ID=clank-cli
# CLANK_AUTH_SCOPES=openid email

# Static bearer the dev clankd accepts on every inbound request, AND
# the HS256 secret it uses to verify JWTs minted by clank-auth-stub.
# Either is sufficient for auth. Laptop dev profiles use the JWT
# path (via `clank login`); static-token profiles use the bearer
# directly. Change both before exposing this stack.
CLANK_AUTH_TOKEN=clank-dev-token-change-me

# Embedded sync substrate settings (read by clankd in TCP mode).
CLANK_BUCKET=clank
CLANK_SYNC_PRESIGN_TTL=5m

# Publicly-reachable URL of the minio bucket. Baked into presigned
# URLs so a remote sprite (fly.io etc.) can pull from the same
# hostname the laptop uses for upload AND the sprite uses for upload
# during pull-back. Leave empty for laptop-only smoke testing (relies
# on `127.0.0.1 clank-minio` in /etc/hosts). For a real sprite, run
# `make dev` to spawn a cloudflared tunnel and auto-write this value;
# or `make tunnel` and paste manually.
# CLANK_SYNC_S3_PUBLIC_ENDPOINT=https://<words>.trycloudflare.com
